# Learny backend — production env template (AD-042/AD-043).
#
# Split into ./secrets/*.env files referenced by docker-compose.prod.yml:
#   - ./secrets/api.env     → the `api` service
#   - ./secrets/worker.env  → the `worker` service
#   - ./secrets/db.env      → the `db` service (POSTGRES_PASSWORD)
#   - ./secrets/minio.env   → the `minio` service (MINIO_ROOT_USER/PASSWORD)
#   - ./secrets/backup.env  → the `backup` service (schedule/retention/offsite/heartbeat)
# Copy the relevant lines into those files with REAL values; never commit them
# (the `secrets/` directory is git-ignored). Non-secret prod config
# (LEARNY_ENVIRONMENT, LEARNY_SESSION_COOKIE_SECURE, LEARNY_LOG_FORMAT) is set
# inline in the compose overlay and does not belong here.

# --- ./secrets/db.env ---
POSTGRES_PASSWORD=change-me-strong-db-password

# --- ./secrets/minio.env ---
MINIO_ROOT_USER=change-me-storage-access-key
MINIO_ROOT_PASSWORD=change-me-strong-storage-secret

# --- ./secrets/api.env  and  ./secrets/worker.env ---
# Database URL (embeds the DB password above).
LEARNY_DATABASE_URL=postgresql+psycopg://learny:change-me-strong-db-password@db:5432/learny
# S3-compatible object storage credentials (match minio.env, or a real provider).
LEARNY_STORAGE_ACCESS_KEY=change-me-storage-access-key
LEARNY_STORAGE_SECRET_KEY=change-me-strong-storage-secret

# --- ./secrets/api.env only ---
# Trusted browser origin(s) for the CSRF Origin/Referer check (AD-007). Must be
# the public HTTPS origin the app is served from, comma-separated if several.
LEARNY_CSRF_TRUSTED_ORIGINS=https://your-domain.example
# Uvicorn worker processes (tune to CPU; defaults to 2 in the compose command).
LEARNY_API_WORKERS=2
# Per-format upload byte caps (optional; shown at their defaults). PDFs are larger
# than EPUBs on average, so the PDF cap is higher.
# LEARNY_EPUB_MAX_BYTES=52428800
# LEARNY_PDF_MAX_BYTES=104857600

# --- ./secrets/backup.env ---
# Consumed by the `backup` service (RFC-003 Cycle A). It also reads POSTGRES_PASSWORD
# from db.env and MINIO_ROOT_USER/PASSWORD from minio.env (reused, not duplicated
# here). Every value below is optional and shown at its default.
# Nightly dump schedule (crond format).
LEARNY_BACKUP_CRON=30 3 * * *
# Days of local dumps to keep (and offsite dumps, when configured); older ones prune.
LEARNY_BACKUP_KEEP_DAYS=14
# Source object bucket mirrored offsite (matches LEARNY_STORAGE_BUCKET).
LEARNY_BACKUP_SOURCE_BUCKET=learny-sources
# Offsite S3-compatible target. Leave ALL FOUR blank to keep backups local-only;
# set all four to also copy each dump offsite and mirror the source bucket there.
LEARNY_BACKUP_REMOTE_ENDPOINT=
LEARNY_BACKUP_REMOTE_ACCESS_KEY=
LEARNY_BACKUP_REMOTE_SECRET_KEY=
LEARNY_BACKUP_REMOTE_BUCKET=
# Optional dead-man's-switch URL, pinged only after a fully successful run.
LEARNY_BACKUP_HEARTBEAT_URL=
