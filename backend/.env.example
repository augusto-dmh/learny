# Learny backend environment contract (NFR-SEC-003).
# Copy to .env for local runs; never commit real secrets.

LEARNY_ENVIRONMENT=local
LEARNY_DEBUG=false

# PostgreSQL (SQLAlchemy + psycopg v3 URL)
LEARNY_DATABASE_URL=postgresql+psycopg://learny:learny@localhost:5432/learny

# Session cookie attributes (NFR-SEC-002)
LEARNY_SESSION_COOKIE_NAME=learny_session
LEARNY_SESSION_COOKIE_SECURE=true
LEARNY_SESSION_COOKIE_SAMESITE=lax
LEARNY_SESSION_COOKIE_PATH=/

# Object storage (S3-compatible; MinIO locally, AD-011)
LEARNY_STORAGE_ENDPOINT=http://localhost:9000
LEARNY_STORAGE_ACCESS_KEY=learny
LEARNY_STORAGE_SECRET_KEY=learny-dev-secret
LEARNY_STORAGE_BUCKET=learny-sources
LEARNY_STORAGE_REGION=us-east-1

# Upload limits (AD-009) — 50 MiB EPUB cap
LEARNY_EPUB_MAX_BYTES=52428800

# Embeddings (ADR-0007/0019) — provider/model live only in the adapter.
# LEARNY_EMBEDDING_PROVIDER selects the adapter: "local" (default, deterministic
# and network-free — CI/tests need no key) or "openai". LEARNY_OPENAI_API_KEY is
# required only when the provider is "openai" (env-only secret; never committed).
# LEARNY_EMBEDDING_MODEL / LEARNY_EMBEDDING_DIMENSIONS are the OpenAI model name and
# vector size; the deterministic adapter ignores them.
LEARNY_EMBEDDING_DIM=1536
LEARNY_EMBEDDING_PROVIDER=local
LEARNY_OPENAI_API_KEY=
LEARNY_EMBEDDING_MODEL=text-embedding-3-large
LEARNY_EMBEDDING_DIMENSIONS=1536
LEARNY_EMBEDDING_BATCH_SIZE=128

# Hybrid retrieval tuning (ADR-0006)
LEARNY_RETRIEVAL_SEMANTIC_LIMIT=50
LEARNY_RETRIEVAL_LEXICAL_LIMIT=50
LEARNY_RETRIEVAL_RRF_K=60
LEARNY_RETRIEVAL_TOP_K=10
LEARNY_RETRIEVAL_MAX_TOP_K=50
LEARNY_HNSW_EF_SEARCH=100
