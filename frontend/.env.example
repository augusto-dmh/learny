# Learny frontend environment contract.
# Copy to .env.local for local runs; never commit real secrets.

# Server-side base URL the same-origin proxy forwards to (ADR-017).
# This is read only on the server; it is never exposed to the browser.
LEARNY_API_BASE_URL=http://localhost:8000

# Public origin this app is served from. The proxy forwards this as the `Origin`
# header to FastAPI when the browser omits one, so FastAPI's Origin/Referer CSRF
# gate (AD-007) passes on register/login/logout. Server-side only.
LEARNY_APP_ORIGIN=http://localhost:3000

# REQUIRED on the BACKEND for browser auth to work: the FastAPI service must
# trust this app's origin for state-changing requests. Set on the `api` service:
#   LEARNY_CSRF_TRUSTED_ORIGINS=http://localhost:3000
# (comma-separated list; must include LEARNY_APP_ORIGIN above). See backend
# Settings.csrf_trusted_origins. The session cookie name is `learny_session`
# (backend Settings.session_cookie_name) and is HttpOnly — never read it from JS.
