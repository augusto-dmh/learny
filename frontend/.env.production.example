# Learny frontend — production env template (AD-042).
# Server-side only; never exposed to the browser. Set on the `web` service (e.g.
# via ./secrets/web.env or the deployment environment).

# Internal base URL the same-origin proxy forwards to (ADR-017). Inside the
# compose network this is the api service; behind a reverse proxy it stays
# server-side.
LEARNY_API_BASE_URL=http://api:8000

# Public origin this app is served from (HTTPS in production). Forwarded as the
# Origin header to FastAPI when the browser omits one, so the CSRF gate (AD-007)
# passes. Must match LEARNY_CSRF_TRUSTED_ORIGINS on the api service.
LEARNY_APP_ORIGIN=https://your-domain.example
